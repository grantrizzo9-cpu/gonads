{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's public profile data.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The user's unique username."
        },
        "displayName": {
            "type": "string",
            "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        }
      },
      "required": ["username", "email"]
    },
    "Website": {
        "title": "Generated Website",
        "description": "An entire website stored as a single HTML string.",
        "type": "object",
        "properties": {
            "htmlContent": {
                "type": "string",
                "description": "The full HTML content of the generated website."
            },
            "themeName": {
                "type": "string",
                "description": "The name of the theme used for the website."
            },
            "createdAt": {
                "type": "string",
                "format": "date-time",
                "description": "The timestamp when the website was created."
            }
        },
        "required": ["htmlContent", "themeName", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Stores public information for each user."
    },
    "/users/{userId}/websites/{websiteId}": {
        "schema": { "$ref": "#/backend/entities/Website" },
        "description": "Stores websites generated by users."
    }
  }
}
